<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.admin.GenerateScheduleDialogController"
      stylesheets="@../../css/styles.css"
      spacing="16" style="-fx-padding: 24; -fx-min-width: 400;">

    <Label text="Параметры генерации расписания" styleClass="label-section"/>

    <VBox styleClass="card" spacing="12">
        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="180" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Занятий в неделю:"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Spinner fx:id="lessonsSpinner" min="1" max="5" initialValue="2"
                     editable="true" prefWidth="80"
                     GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Перезаписать существующие:"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <CheckBox fx:id="overwriteCheck"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>

        <Label text="⚠  При включённой перезаписи старое расписание групп будет удалено"
               wrapText="true"
               style="-fx-text-fill: #C05621; -fx-font-size: 11px;"/>
    </VBox>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Отмена"      onAction="#onCancel"   styleClass="button-secondary"/>
        <Button text="Сгенерировать" onAction="#onConfirm" styleClass="button-primary"/>
    </HBox>
</VBox>
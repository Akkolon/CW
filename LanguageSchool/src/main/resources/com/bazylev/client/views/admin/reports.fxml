<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.admin.ReportsController"
      stylesheets="@../../css/styles.css" spacing="16">
    <Label text="Отчёты и аналитика" styleClass="label-title"/>
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <!-- Левая панель — параметры -->
        <VBox styleClass="card" spacing="14" minWidth="300" maxWidth="300">
            <Label text="Параметры отчёта" styleClass="label-section"/>
            <VBox spacing="6">
                <Label text="Тип отчёта:"/>
                <ComboBox fx:id="reportTypeCombo" maxWidth="Infinity" onAction="#onTypeChange"/>
            </VBox>
            <VBox spacing="6">
                <Label text="Группа:"/>
                <ComboBox fx:id="groupCombo" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="6">
                <Label text="Период с:"/>
                <DatePicker fx:id="fromDate" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="6">
                <Label text="Период по:"/>
                <DatePicker fx:id="toDate" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="6">
                <Label text="Формат:"/>
                <ComboBox fx:id="formatCombo" maxWidth="Infinity"/>
            </VBox>
            <Pane VBox.vgrow="ALWAYS"/>
            <Button text="📊  Сформировать отчёт" onAction="#onGenerate"
                    styleClass="button-primary" maxWidth="Infinity"/>
            <Button text="📜  Генерация сертификата" onAction="#onCertificate"
                    styleClass="button-secondary" maxWidth="Infinity"/>
        </VBox>
        <!-- Правая панель — предпросмотр -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="12">
            <Label text="Предпросмотр" styleClass="label-section"/>
            <TextArea fx:id="previewArea" VBox.vgrow="ALWAYS" editable="false"
                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 12px;"/>
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button text="💾  Сохранить CSV" onAction="#onSaveCsv" styleClass="button-secondary"/>
                <Button text="📄  Сохранить PDF" onAction="#onSavePdf" styleClass="button-secondary"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
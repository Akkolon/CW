<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.admin.GroupStudentsController"
      stylesheets="@../../css/styles.css"
      spacing="16" style="-fx-padding: 24; -fx-min-width: 540; -fx-min-height: 400;">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="titleLabel" text="Студенты группы" styleClass="label-section"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="🔄  Обновить" onAction="#onRefresh" styleClass="button-secondary"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="ID"       prefWidth="70"/>
            <TableColumn fx:id="colName"   text="ФИО"      prefWidth="280"/>
            <TableColumn fx:id="colDate"   text="Дата зачисления" prefWidth="140"/>
            <TableColumn fx:id="colStatus" text="Статус"   prefWidth="110"/>
        </columns>
        <placeholder><Label text="Студентов не найдено"/></placeholder>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="countLabel" text="Всего: 0" styleClass="label-subtitle"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Закрыть" onAction="#onClose" styleClass="button-secondary"/>
    </HBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.admin.StudentsController"
      stylesheets="@../../css/styles.css" spacing="16">
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Студенты" styleClass="label-title"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="+ Добавить студента" onAction="#onCreate" styleClass="button-primary"/>
    </HBox>
    <HBox styleClass="card" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍  Поиск..." styleClass="search-field"
                   prefWidth="280" onKeyReleased="#onSearch"/>
        <Button text="Сбросить" onAction="#onReset" styleClass="button-secondary"/>
    </HBox>
    <TableView fx:id="table" VBox.vgrow="ALWAYS" onMouseClicked="#onDoubleClick">
        <columns>
            <TableColumn fx:id="colId"     text="ID"        prefWidth="60"/>
            <TableColumn fx:id="colPerson" text="ФИО"       prefWidth="260"/>
            <TableColumn fx:id="colDate"   text="Дата записи" prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Статус"    prefWidth="100"/>
        </columns>
        <placeholder><Label text="Студенты не найдены"/></placeholder>
    </TableView>
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label fx:id="countLabel" text="Всего: 0" styleClass="label-subtitle"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="✏️  Изменить"  onAction="#onEdit"    styleClass="button-secondary"/>
        <Button text="📋  История"   onAction="#onHistory"  styleClass="button-secondary"/>
        <Button text="🗑  Удалить"   onAction="#onDelete"   styleClass="button-danger"/>
    </HBox>
</VBox>

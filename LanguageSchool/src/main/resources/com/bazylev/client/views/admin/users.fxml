<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.admin.UsersController"
      stylesheets="@../../css/styles.css"
      spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Пользователи" styleClass="label-title"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="+ Создать" onAction="#onCreate" styleClass="button-primary"/>
        <Button text="✎ Изменить" onAction="#onEdit" styleClass="button-secondary"/>
        <Button text="🔒/🔓" onAction="#onBlock" styleClass="button-secondary"/>
        <Button text="🗑 Удалить" onAction="#onDelete" styleClass="button-secondary"/>
    </HBox>

    <HBox styleClass="card" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Поиск по логину" prefWidth="220"
                   onKeyReleased="#onSearch"/>
        <ComboBox fx:id="roleFilter" prefWidth="160" onAction="#onFilter"/>
        <Button text="Сбросить" onAction="#onReset" styleClass="button-secondary"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" text="Всего: 0" styleClass="label-subtitle"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"      text="ID"         prefWidth="70"/>
            <TableColumn fx:id="colLogin"   text="Логин"      prefWidth="220"/>
            <TableColumn fx:id="colFullName" text="ФИО"       prefWidth="260"/>
            <TableColumn fx:id="colRole"    text="Роль"       prefWidth="170"/>
            <TableColumn fx:id="colBlocked" text="Статус"     prefWidth="190"/>
        </columns>
        <placeholder><Label text="Пользователи не найдены"/></placeholder>
    </TableView>
</VBox>
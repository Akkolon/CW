<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.admin.GroupScheduleController"
      stylesheets="@../../css/styles.css"
      spacing="16" style="-fx-padding: 24; -fx-min-width: 540; -fx-min-height: 400;">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="titleLabel" text="Расписание группы" styleClass="label-section"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="🔄  Обновить" onAction="#onRefresh" styleClass="button-secondary"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDay"   text="День недели" prefWidth="150"/>
            <TableColumn fx:id="colStart" text="Начало"      prefWidth="100"/>
            <TableColumn fx:id="colEnd"   text="Конец"       prefWidth="100"/>
            <TableColumn fx:id="colRoom"  text="Аудитория"   prefWidth="120"/>
        </columns>
        <placeholder><Label text="Расписание не найдено"/></placeholder>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button text="Закрыть" onAction="#onClose" styleClass="button-secondary"/>
    </HBox>
</VBox>
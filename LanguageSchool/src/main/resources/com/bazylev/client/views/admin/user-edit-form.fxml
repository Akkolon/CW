<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.admin.UserEditFormController"
      stylesheets="@../../css/styles.css"
      spacing="16" style="-fx-padding: 24; -fx-min-width: 460;">

    <Label text="Редактировать пользователя" styleClass="label-section"/>

    <VBox styleClass="card" spacing="12">
        <Label text="Учётная запись" styleClass="label-subtitle"/>
        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Логин:"              GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="loginField"     GridPane.rowIndex="0" GridPane.columnIndex="1"
                       disable="true"
                       style="-fx-opacity: 0.7;"/>

            <Label text="Роль:"               GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="roleCombo"       GridPane.rowIndex="1" GridPane.columnIndex="1"
                      maxWidth="Infinity"/>

            <Label text="Новый пароль:"       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <PasswordField fx:id="passwordField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                           promptText="Оставьте пустым, чтобы не менять"/>

            <Label text="Повторите пароль:"   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <PasswordField fx:id="passwordRepeatField" GridPane.rowIndex="3" GridPane.columnIndex="1"
                           promptText="Оставьте пустым, чтобы не менять"/>
        </GridPane>
    </VBox>

    <VBox styleClass="card" spacing="12">
        <Label text="Личные данные" styleClass="label-subtitle"/>
        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Фамилия:"            GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="lastNameField"  GridPane.rowIndex="0" GridPane.columnIndex="1"
                       promptText="Иванов"/>

            <Label text="Имя:"                GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="firstNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"
                       promptText="Иван"/>

            <Label text="Отчество:"           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="middleNameField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                       promptText="Иванович (необязательно)"/>

            <Label text="Email:"              GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="emailField"     GridPane.rowIndex="3" GridPane.columnIndex="1"
                       promptText="ivanov@mail.ru (необязательно)"/>
        </GridPane>
    </VBox>

    <Label fx:id="errorLabel" text="" wrapText="true"
           style="-fx-text-fill: #E53E3E; -fx-font-size: 12px;
                  -fx-background-color: #FFF5F5; -fx-background-radius: 6;
                  -fx-border-color: #FEB2B2; -fx-border-radius: 6;
                  -fx-border-width: 1; -fx-padding: 8 12 8 12;"
           visible="false" managed="false"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Отмена"    onAction="#onCancel" styleClass="button-secondary"/>
        <Button text="Сохранить" onAction="#onSave"   styleClass="button-primary"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.teacher.AttendanceEditFormController"
      stylesheets="@../../css/styles.css"
      spacing="16" style="-fx-padding: 24; -fx-min-width: 380;">

    <Label text="Редактировать запись посещаемости" styleClass="label-section"/>

    <VBox styleClass="card" spacing="12">
        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Студент:"          GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="studentLabel"     GridPane.rowIndex="0" GridPane.columnIndex="1"
                   style="-fx-font-weight: bold;"/>

            <Label text="Дата занятия:"     GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <DatePicker fx:id="datePicker"  maxWidth="Infinity"
                        GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Статус:"           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="statusCombo"   maxWidth="Infinity"
                      GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Причина:"          GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="commentField" promptText="Необязательно"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <Label fx:id="errorLabel" text="" wrapText="true"
           style="-fx-text-fill: #E53E3E; -fx-font-size: 12px;
                  -fx-background-color: #FFF5F5; -fx-background-radius: 6;
                  -fx-border-color: #FEB2B2; -fx-border-radius: 6;
                  -fx-border-width: 1; -fx-padding: 8 12 8 12;"
           visible="false" managed="false"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Отмена"    onAction="#onCancel" styleClass="button-secondary"/>
        <Button text="Сохранить" onAction="#onSave"   styleClass="button-primary"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bazylev.client.controllers.shared.RegisterController"
           stylesheets="@../../css/styles.css"
           style="-fx-background-color: #F0F4F8;">

    <VBox alignment="CENTER" spacing="0"
          maxWidth="520" maxHeight="560"
          style="-fx-background-color: white;
                 -fx-background-radius: 12;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 4);">

        <VBox alignment="CENTER" spacing="6"
              style="-fx-background-color: #2C3E6B;
                     -fx-background-radius: 12 12 0 0;
                     -fx-padding: 28 32 22 32;">
            <Label text="Регистрация"
                   style="-fx-text-fill: white;
                          -fx-font-size: 16px;
                          -fx-font-weight: bold;"/>
            <Label text="Создание аккаунта студента"
                   style="-fx-text-fill: #A8C0E8;
                          -fx-font-size: 12px;"/>
        </VBox>

        <VBox spacing="14" style="-fx-padding: 24 32 22 32;">

            <HBox spacing="12">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Фамилия" style="-fx-font-size: 12px; -fx-text-fill: #4A5568; -fx-font-weight: bold;"/>
                    <TextField fx:id="lastNameField" promptText="Иванов" style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #CBD5E0; -fx-border-radius: 6; -fx-border-width: 1; -fx-background-color: white;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Имя" style="-fx-font-size: 12px; -fx-text-fill: #4A5568; -fx-font-weight: bold;"/>
                    <TextField fx:id="firstNameField" promptText="Иван" style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #CBD5E0; -fx-border-radius: 6; -fx-border-width: 1; -fx-background-color: white;"/>
                </VBox>
            </HBox>

            <VBox spacing="6">
                <Label text="Отчество (необязательно)" style="-fx-font-size: 12px; -fx-text-fill: #4A5568; -fx-font-weight: bold;"/>
                <TextField fx:id="middleNameField" promptText="Иванович" style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #CBD5E0; -fx-border-radius: 6; -fx-border-width: 1; -fx-background-color: white;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Email (необязательно)" style="-fx-font-size: 12px; -fx-text-fill: #4A5568; -fx-font-weight: bold;"/>
                <TextField fx:id="emailField" promptText="ivan@example.com" style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #CBD5E0; -fx-border-radius: 6; -fx-border-width: 1; -fx-background-color: white;"/>
            </VBox>

            <HBox spacing="12">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Логин" style="-fx-font-size: 12px; -fx-text-fill: #4A5568; -fx-font-weight: bold;"/>
                    <TextField fx:id="loginField" promptText="login" style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #CBD5E0; -fx-border-radius: 6; -fx-border-width: 1; -fx-background-color: white;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Пароль" style="-fx-font-size: 12px; -fx-text-fill: #4A5568; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField" promptText="••••••••" style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #CBD5E0; -fx-border-radius: 6; -fx-border-width: 1; -fx-background-color: white;"/>
                </VBox>
            </HBox>

            <VBox spacing="6">
                <Label text="Повторите пароль" style="-fx-font-size: 12px; -fx-text-fill: #4A5568; -fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordRepeatField" promptText="••••••••" style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #CBD5E0; -fx-border-radius: 6; -fx-border-width: 1; -fx-background-color: white;"/>
            </VBox>

            <Label fx:id="errorLabel"
                   text=""
                   wrapText="true"
                   style="-fx-text-fill: #E53E3E;
                          -fx-font-size: 12px;
                          -fx-background-color: #FFF5F5;
                          -fx-background-radius: 6;
                          -fx-border-color: #FEB2B2;
                          -fx-border-radius: 6;
                          -fx-border-width: 1;
                          -fx-padding: 8 12 8 12;"
                   visible="false" managed="false"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Назад"
                        onAction="#onBack"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #2C3E6B;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-padding: 8 10;
                               -fx-cursor: hand;"/>
                <Button fx:id="registerButton"
                        text="Зарегистрироваться"
                        onAction="#onRegister"
                        style="-fx-background-color: #2C3E6B;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-padding: 10 14;
                               -fx-background-radius: 6;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>


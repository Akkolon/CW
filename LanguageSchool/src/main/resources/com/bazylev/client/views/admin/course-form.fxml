<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bazylev.client.controllers.admin.CourseFormController"
      stylesheets="@../../css/styles.css"
      spacing="16" style="-fx-padding: 24; -fx-min-width: 420;">

    <Label fx:id="titleLabel" text="Создать курс" styleClass="label-section"/>

    <VBox styleClass="card" spacing="12">
        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="130" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Название:"        GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="nameField"   promptText="Английский язык"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Описание:"        GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="descField"   promptText="Необязательно"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Уровень:"         GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="levelCombo"   maxWidth="Infinity"
                      GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Часов всего:"     GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Spinner fx:id="hoursSpinner"  min="1" max="500" initialValue="80" editable="true"
                     GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="120"/>

            <Label text="Цена/мес. (руб.):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="priceField"  promptText="0.00"
                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Активен:"         GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <CheckBox fx:id="activeCheck"  selected="true"
                      GridPane.rowIndex="5" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Отмена"    onAction="#onCancel" styleClass="button-secondary"/>
        <Button text="Сохранить" onAction="#onSave"   styleClass="button-primary"/>
    </HBox>
</VBox>